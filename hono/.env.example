NODE_ENV=development
APP_PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onboarding_portal
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-at-least-32-chars
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
ALLOW_ADMIN_REGISTRATION=false
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_PARENT_FOLDER_ID=
