# Hono server port
APP_PORT=3000

# PostgreSQL connection string used by Bun app and drizzle-kit
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assanpay_onboarding

# JWT secrets must be at least 32 characters
JWT_ACCESS_SECRET=replace-with-a-32-char-min-access-secret
JWT_REFRESH_SECRET=replace-with-a-32-char-min-refresh-secret

# Token lifetimes
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Feature flags
ALLOW_ADMIN_REGISTRATION=false

# Cookie settings
# Leave COOKIE_DOMAIN unset for localhost
COOKIE_SECURE=false

# Frontend origin allowed by backend CORS
CORS_ORIGIN=http://localhost:5173
